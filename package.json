{
    "name": "rate-a-prompt",
    "version": "0.1.0",
    "private": true,
    "description": "Evaluate and compare LLM prompt quality side-by-side",
    "license": "MIT",
    "author": "Nikita Snetkov (https://github.com/dibenkobit)",
    "repository": {
        "type": "git",
        "url": "https://github.com/dibenkobit/rate-a-prompt.git"
