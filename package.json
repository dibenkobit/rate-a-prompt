        "@streamdown/math": "^1.0.2",
        "@streamdown/mermaid": "^1.0.2",
        "@tailwindcss/typography": "^0.5.20",
        "@trpc/client": "^11.18.0",
        "@trpc/server": "^11.18.0",
        "@uiw/codemirror-theme-github": "^4.25.10",
        "@uiw/react-codemirror": "^4.25.10",
        "@vercel/analytics": "^2.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "geist": "^1.7.2",
        "lucide-react": "^1.21.0",
        "motion": "^12.42.0",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "shadcn": "^4.12.0",
        "streamdown": "^2.5.0",
        "superjson": "^2.2.6",
